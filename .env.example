# ===========================================================
# Opsling configuration
# Copy to .env and fill in the required values.
# ===========================================================

# --- Telegram (required) -----------------------------------
# Create a bot with @BotFather, then send it a message and grab
# the chat id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Identity ----------------------------------------------
# Shown in every alert message. Defaults to the OS hostname.
HOSTNAME_LABEL=

# --- What to watch -----------------------------------------
# By default Opsling watches every running container. List
# names in IGNORE_CONTAINERS to exclude specific ones (e.g.
# noisy sidecars, your own monitoring stack). The default
# already includes "opsling" so the watchdog doesn't alert
# on its own restarts; set to an empty value to disable that
# and watch yourself too.
#
# Two interchangeable notations:
#   IGNORE_CONTAINERS=opsling,traefik,watchtower
#   IGNORE_CONTAINERS=["opsling","traefik","watchtower"]
# Same goes for LOG_ERROR_PATTERNS and LOG_IGNORE_PATTERNS below.
IGNORE_CONTAINERS=opsling

# --- System thresholds (percent unless noted) --------------
# Opsling alerts on the HOST's resources. Per-container CPU/memory
# limits aren't separately tracked — container restarts, OOM kills,
# and error logs cover the "this specific container is broken" case.
CPU_THRESHOLD=85
MEMORY_THRESHOLD=85
DISK_THRESHOLD=90
LOAD_THRESHOLD=4.0

# --- Log scanning ------------------------------------------
# Comma-separated patterns. Matched case-insensitively as
# substrings (or regex if prefixed with "re:").
LOG_ERROR_PATTERNS=ERROR,FATAL,panic,Exception,Traceback
LOG_IGNORE_PATTERNS=
LOG_ALERT_MIN_OCCURRENCES=3
LOG_ALERT_WINDOW_SECONDS=60

# --- Cadence (seconds) -------------------------------------
SYSTEM_INTERVAL_SECONDS=30
DISK_INTERVAL_SECONDS=300

# --- Alerting behavior -------------------------------------
# How many consecutive readings must cross the threshold
# before firing (and before recovering).
REQUIRE_CONSECUTIVE=2

# Minutes to wait before re-notifying about an ongoing
# incident. 0 disables re-notifications entirely
# (one alert per incident).
RENOTIFY_AFTER_MINUTES=30

# Send a ✅ recovery message when an incident clears.
SEND_RECOVERY=true

# Daily "I'm alive" heartbeat. 24h time HH:MM in TZ.
# Leave empty to disable.
DAILY_HEARTBEAT_AT=

# --- Misc --------------------------------------------------
LOG_LEVEL=info
HTTP_PORT=4717
NODE_ENV=production
TZ=UTC

# --- Advanced ----------------------------------------------
# When Opsling runs in Docker, the container only sees its own
# overlay filesystem by default. Mount the host root read-only
# (handled in docker-compose.yml) and point HOST_FS_ROOT at it
# so disk monitoring reflects the HOST's disks.
# Leave empty when running natively (e.g. `pnpm dev` on your laptop).
HOST_FS_ROOT=
