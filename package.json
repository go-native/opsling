{
  "name": "opsling",
  "version": "0.1.0",
  "description": "Tiny Telegram-first monitoring watchdog for indie hackers running a single VPS.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opsling": "dist/index.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "changeset publish"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "dockerode": "^4.0.2",
    "dotenv": "^16.4.5",
    "nanoid": "^5.0.7",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "systeminformation": "^5.23.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/dockerode": "^3.3.31",
    "@types/node": "^22.7.4",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/go-native/opsling.git"
  },
  "keywords": ["monitoring", "docker", "telegram", "alerts", "indie-hacker", "vps", "self-hosted"]
}
